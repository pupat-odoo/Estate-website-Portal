<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="estate_website_page.property_cards_template">
            <div class="list-view-layout">
                <div class="row">
                    <t t-foreach="properties" t-as="prop" t-key="prop.id">
                        <div class="col-12 mb-4"> 
                            <div class=" property-snippet d-flex align-items-center border shadow-sm rounded overflow-hidden bg-white p-3">
                                <img t-att-src="'/web/image/estate.property/' + prop.id + '/image'"
                                    style="width: 250px; height: 180px; object-fit: cover;" class="rounded"/>
                                <div class="d-flex flex-column flex-grow-1 px-4 gap-2">
                                    <h4 class="fw-bold mb-0" t-out="prop.name"/>
                                    <p class="text-muted mb-0" t-out="prop.description" style="max-height: 50px; overflow: hidden;"/>
                                    <div class="mt-auto">
                                        <span class="h5 text-primary fw-bold" t-out="prop.expected_price"/>
                                    </div>
                                </div>
                                <div class="ms-auto ps-3 border-start">
                                    <a t-att-href="'/estate/bid/' + prop.id" class="btn btn-primary px-4">
                                        Bid
                                    </a>
                                </div>
                            </div>
                        </div>
                    </t>
                </div>
            </div>  
    </t>
</templates>
