<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="estate_website_page.PropertyListingSnippetOption"
        data-selector=".s_property_listing_snippet">
        <BuilderRow label.translate="Layout">
            <BuilderButtonGroup action="'propertyLayout'"> 
                <BuilderButton  actionParam="'card'">Card</BuilderButton>
                <BuilderButton  actionParam="'list'">List</BuilderButton>
            </BuilderButtonGroup>
        </BuilderRow>
        <BuilderRow label.translate="Property Type">
            <BuilderSelect action="'propertyType'">
                <BuilderSelectItem actionParam="'1'">Home</BuilderSelectItem>
                <BuilderSelectItem actionParam="'4'">Palace</BuilderSelectItem>
                <BuilderSelectItem actionParam="'2'">Villa</BuilderSelectItem>
                <BuilderSelectItem actionParam="'3'">Penthouse</BuilderSelectItem>
            </BuilderSelect>
        </BuilderRow>
        <BuilderRow label.translate="Colors">
            <BuilderColorPicker applyTo="'.property-snippet'" styleAction="'background-color'" enabledTabs="['solid', 'custom']"/>
        </BuilderRow> 
    </t>
</templates>
