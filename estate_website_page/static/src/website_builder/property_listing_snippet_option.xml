<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="estate_website_page.PropertyListingSnippetOption"
        data-selector=".s_property_listing_snippet">
        <BuilderRow label.translate="Property Type">
            <BuilderButton classAction="'propertyListingSnippetOption'" mainParam="'card'">Card</BuilderButton>
            <BuilderButton classAction="'propertyListingSnippetOption'" mainParam="'list'">List</BuilderButton>
        </BuilderRow>
        <BuilderRow label.translate="Property Type">
            <BuilderSelect>
                <BuilderSelectItem classAction="'propertyListingSnippetOption'" mainParam="'Home'">Home</BuilderSelectItem>
                <BuilderSelectItem classAction="'propertyListingSnippetOption'"  mainParam="'Palace'">Palace</BuilderSelectItem>
                <BuilderSelectItem classAction="'propertyListingSnippetOption'" mainParam="'Villa'">Villa</BuilderSelectItem>
                <BuilderSelectItem classAction="'propertyListingSnippetOption'"  mainParam="'Penthouse'">Penthouse</BuilderSelectItem>
            </BuilderSelect>
        </BuilderRow>
        <BuilderRow label.translate="Colors">
            <BuilderColorPicker applyTo="'.property-snippet'" styleAction="'background-color'" enabledTabs="['solid', 'custom']"/>
        </BuilderRow> 
    </t>
</templates>
