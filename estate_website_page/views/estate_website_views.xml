<odoo>
    <record id="menu_estate" model="website.menu">
            <field name="name">Estate</field>
            <field name="url">/estate</field>
            <field name="parent_id" ref="website.main_menu"/>
            <field name="sequence" type="int">20</field>
    </record>

    <record id="view_property_form_inherit_image" model="ir.ui.view">
        <field name="name">estate.property.form.image</field>
        <field name="model">estate.property</field>
        <field name="inherit_id" ref="estate.estate_property_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group" position="inside">
                <field name="image" widget="image" class="oe_avatar"/>
            </xpath>
        </field>
    </record>
</odoo>
