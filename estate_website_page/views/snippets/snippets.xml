<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="s_property_listing_snippet" name="Property Listing">
            <section class="s_property_listing_snippet">
                <div class="container">
                    <h2>Properties</h2>
                    <div class="property_container"></div>
                </div>
            </section>
    </template>
    
    <template id="snippets" inherit_id="website.snippets" name="Snippets">

        <xpath expr="//snippets[@id='snippet_groups']/*[1]" position="before">
                <t t-snippet="website.s_snippet_group"
                    string="Property"
                    group="property"
                    t-thumbnail="/estate_website_page/static/src/img/wbuilder/property_rating.png"/>
        </xpath>
    
        <xpath expr="//snippets[@id='snippet_structure']/*[1]" position="before">
            <t t-snippet="estate_website_page.s_property_snippet" 
                group="property"
                string="Property snippet"
                keywords="property,snippet"/>   
        </xpath>

        <xpath expr="//snippets[@id='snippet_structure']" position="inside">
            <t t-snippet="estate_website_page.s_property_load_snippet" 
                    string="Demo Property"
                    group="columns"
                    t-thumbnail="/estate_website_page/static/src/img/wbuilder/Property_column.jpeg">
                <keywords>property,snippet</keywords>
            </t>
        </xpath>

        

        <xpath expr="//snippets[@id='snippet_structure']" position="inside">
            <t t-snippet="estate_website_page.s_property_listing_snippet" 
                    string=" My Property"
                    group="columns"
                    t-thumbnail="/estate_website_page/static/src/img/wbuilder/Property_column.jpeg">
                <keywords>property,snippet</keywords>
            </t>
        </xpath>

        <xpath expr="//snippets[@id='snippet_content']/*[1]" position="before">
            <t t-snippet="estate_website_page.s_property_snippet" 
                group="property"
                string="Custom snippet"
                t-thumbnail="/estate_website_page/static/src/img/wbuilder/property_rating.png"
                keywords="property,snippet"/>    
        </xpath>
    </template>
</odoo>
