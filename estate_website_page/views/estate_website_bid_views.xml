<?xml version="1.0" encoding="UTF-8"?>
<odoo>


    <record id="estate_bid_action" model="ir.actions.act_window">
        <field name="name"> Estate Website Bid</field>
        <field name="res_model">estate.property</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="estate_website_bid_view_form" model="ir.ui.view">
        <field name="name">estate.website.bid.form</field>
        <field name="model">estate.website.bid</field>
        <field name="arch" type="xml">
                <form string="Estate Bid ">
                        <sheet>
                            <group>
                                
                                <field name="property_id"/>
                                <field name="price"/>           
                            </group>
                        </sheet>
                </form>
        </field>
    </record>

    <record id="estate_website_bid_view_list" model="ir.ui.view">
        <field name="name">estate.website.bid.list</field>
        <field name="model">estate.website.bid</field>
        <field name="arch" type="xml">
            <list string="Estate Bid">
                <field name="property_id"/>
                <field name="price"/>  
            </list>
        </field>
    </record>
</odoo>
